DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sentra_ai
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1):\d+
STORAGE_DIR=storage
UPLOAD_DIR=storage/uploads
AVATAR_DIR=storage/avatars
EXPORT_DIR=storage/exports
AI_MODEL_PATH=app/ai/model.pkl
AI_VECTORIZER_PATH=app/ai/vectorizer.pkl
SEED_DEMO_DATA=false
